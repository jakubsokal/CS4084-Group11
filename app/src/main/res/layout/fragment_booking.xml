<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Floor"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/floorSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Desk"
        android:textSize="18sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/deskSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Seat"
        android:textSize="18sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/seatSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/selectedSeatText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selected Seat: None"
        android:textSize="18sp"
        android:layout_marginTop="24dp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/bookSeatButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Book Seat"
        android:textSize="18sp"
        android:backgroundTint="@color/green"
        android:textColor="@android:color/white"
        android:layout_marginTop="32dp" />
</LinearLayout>
